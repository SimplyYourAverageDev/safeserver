{
	"schemaVersion": 1,
	"id": "safeserver",
	"version": "${version}",
	"name": "Safeserver",
	"description": "Adds password-based authentication to Fabric servers before players can interact with the world.",
	"authors": [
		"SimplyYourAverageDev"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/safeserver",
		"sources": "https://github.com/SimplyYourAverageDev/safeserver"
	},
	"license": "CC0-1.0",
	"icon": "assets/safeserver/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"youraveragedev.safeserver.Safeserver"
		],
		"client": [
			"youraveragedev.safeserver.SafeserverClient"
		],
		"fabric-datagen": [
			"youraveragedev.safeserver.SafeserverDataGenerator"
		]
	},
	"mixins": [
		"safeserver.mixins.json",
		{
			"config": "safeserver.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1.1",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}
